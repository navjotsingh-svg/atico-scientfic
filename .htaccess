<Files .env>
    order allow,deny
    Deny from all
</Files>
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]

RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Remove "index.php/" from URLs

RewriteCond %{THE_REQUEST} /index\.php/ [NC]

RewriteRule ^(.*?)index\.php/(.*)$ /$1$2 [L,R=301,NC]



# Remove double slash

RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ (.*)//(.*)\ HTTP/ [NC]

RewriteRule ^ %1/%2 [R=301,L]



# Remove trailing slash and add .php extension

RewriteCond %{REQUEST_FILENAME} !-d

RewriteRule ^(.*)/$ /$1.php [L]



# Serve files without .php extension

RewriteCond %{REQUEST_FILENAME}.php -f

RewriteRule ^(.*)$ $1.php [L]



# Redirect /index.php to the root directory

RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.php\ HTTP/

RewriteRule ^index\.php$ / [R=301,L]





# Redirect specific old URLs to new URLs

RewriteRule ^product/microslide-boxes$ /product/microslide-boxes-manufacturers-suppliers-and-exporters [R=301,L]

RewriteRule ^product/microslide-cabinet$ /product/microslide-cabinet-manufacturers-suppliers-and-exporters [R=301,L]

RewriteRule ^product/microwave-test-bench-antenna$ /product/microwave-test-bench-antenna-manufacturers-suppliers-and-exporters [R=301,L]

RewriteRule ^product/mig-welding-machine$ /product/mig-welding-machine-manufacturers-suppliers-and-exporters [R=301,L]





RewriteCond %{REQUEST_FILENAME} !-d

RewriteRule ^(.*)/$ /$1 [L,R=301]

RewriteCond %{REQUEST_URI} !(\.ico|\.css|\.js|\.png|\.jpg|\.jpeg|\.webp|\.gif|robots\.txt|\.eot|\.svg|\.ttf|\.woff|\.woff2|\.otf|\.pdf|\.xlsx)$ [NC]

RewriteCond %{REQUEST_FILENAME} !-d

RewriteCond %{REQUEST_FILENAME} !-f

RewriteRule ^ index.php [L]

RewriteCond %{REQUEST_FILENAME} !-d

RewriteCond %{REQUEST_FILENAME} !-f



RewriteCond %{REQUEST_URI} !^/public/uploads

RewriteRule ^(login|uploads|assets|css|js|images|ca|favicons|fonts|)/(.*)$ public/$1/$2 [L,NC]





RewriteCond %{HTTP:Authorization} ^(.*)

RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]



RewriteEngine On

RewriteCond %{REQUEST_URI} !^/public/

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php82” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
